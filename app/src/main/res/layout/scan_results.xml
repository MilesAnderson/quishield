<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    android:layout_gravity="center"
    app:cardCornerRadius="20dp"
    app:cardElevation="16dp">

<!-- Results display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:background="@color/light_gray_bg"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="25dp"
            android:paddingVertical="5dp"
            android:gravity="center">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scan Results"
                android:textSize="28dp"
                android:textStyle="bold"
                android:textColor="@color/blue4"
                android:gravity="center"/>

            <!-- Decoded URL -->
            <TextView
                android:id="@+id/urlText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="URL will appear here."
                android:textSize="18sp"
                android:textColor="#000000"
                android:fontFamily="monospace"
                android:paddingTop="10dp"

                android:breakStrategy="simple"
                android:inputType="textUri"
                android:hyphenationFrequency="none"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#33000000"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"/>

        </LinearLayout>

        <!-- Final Assessment -->
        <TextView
            android:id="@+id/assessmentText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="10dp"
            android:text="Security evaluation will appear here."
            android:textStyle="bold"
            android:textSize="24sp" />

        <!-- Risk Score -->
        <TextView
            android:id="@+id/scoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="5dp"
            android:text="Risk score will appear here."
            android:textStyle="bold"
            android:textSize="18sp" />

        <ProgressBar
            android:id="@+id/riskMeter"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:max="100"
            android:progress="0"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="12dp"/>


        <!-- Reasons -->
        <TextView
            android:id="@+id/reasonsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scan results will appear here."
            android:textSize="15sp"
            android:textColor="#222222"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2b000000"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"/>

    <!-- buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancelButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Cancel"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginEnd="6dp"
                app:cornerRadius="18dp"
                app:backgroundTint="@color/blue3"
                app:rippleColor="@color/ripple_blue_light"/>

            <!-- Visit Link Button: allows for URL activation-->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/visitButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Visit Link"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginStart="6dp"
                app:cornerRadius="18dp"
                app:backgroundTint="@color/blue3"
                app:rippleColor="@color/ripple_blue_light"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>